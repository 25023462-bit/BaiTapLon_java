<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.openjfx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.bidplaza.ui.controller.AuctionDetailController"
            style="-fx-background-color: #f0f4f8;">

    <!-- Header -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color: #2c3e50; -fx-padding: 16;">
            <Button text="← Quay lại" onAction="#handleBack"
                    style="-fx-background-color: transparent; -fx-text-fill: white;
                           -fx-cursor: hand; -fx-border-color: white; -fx-border-radius: 4;
                           -fx-background-radius: 4; -fx-padding: 4 12;"/>
            <Label fx:id="titleLabel" text="Chi tiết đấu giá"
                   style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: white;"/>
        </HBox>
    </top>

    <center>
        <HBox spacing="20">
            <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>

            <!-- Trái: thông tin sản phẩm + đặt giá -->
            <VBox spacing="16" prefWidth="380"
                  style="-fx-background-color: white; -fx-padding: 24;
                         -fx-border-radius: 8; -fx-background-radius: 8;">

                <Label text="Thông tin sản phẩm"
                       style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                <Separator/>

                <HBox spacing="8">
                    <Label text="Tên:" style="-fx-font-weight: bold; -fx-min-width: 120;"/>
                    <Label fx:id="itemNameLabel"/>
                </HBox>
                <HBox spacing="8">
                    <Label text="Loại:" style="-fx-font-weight: bold; -fx-min-width: 120;"/>
                    <Label fx:id="categoryLabel"/>
                </HBox>
                <HBox spacing="8">
                    <Label text="Giá khởi điểm:" style="-fx-font-weight: bold; -fx-min-width: 120;"/>
                    <Label fx:id="startPriceLabel"/>
                </HBox>
                <HBox spacing="8">
                    <Label text="Kết thúc lúc:" style="-fx-font-weight: bold; -fx-min-width: 120;"/>
                    <Label fx:id="endTimeLabel"/>
                </HBox>

                <Separator/>

                <!-- Giá hiện tại nổi bật -->
                <VBox alignment="CENTER" spacing="4"
                      style="-fx-background-color: #eaf4fb; -fx-padding: 16; -fx-border-radius: 8; -fx-background-radius: 8;">
                    <Label text="GIÁ HIỆN TẠI" style="-fx-font-size: 12; -fx-text-fill: #7f8c8d;"/>
                    <Label fx:id="currentPriceLabel" text="\$0"
                           style="-fx-font-size: 32; -fx-font-weight: bold; -fx-text-fill: #e74c3c;"/>
                    <Label fx:id="leaderLabel" text="Người dẫn đầu: --"
                           style="-fx-font-size: 12; -fx-text-fill: #27ae60;"/>
                </VBox>

                <!-- Form đặt giá -->
                <VBox spacing="8">
                    <Label text="Đặt giá của bạn" style="-fx-font-weight: bold;"/>
                    <TextField fx:id="bidAmountField" promptText="Nhập số tiền ($)"
                               style="-fx-padding: 10; -fx-border-radius: 6; -fx-background-radius: 6;"/>
                    <Button text="ĐẶT GIÁ NGAY" prefWidth="330" prefHeight="44"
                            onAction="#handlePlaceBid"
                            style="-fx-background-color: #e74c3c; -fx-text-fill: white;
                                   -fx-font-size: 15; -fx-font-weight: bold;
                                   -fx-border-radius: 6; -fx-background-radius: 6; -fx-cursor: hand;"/>
                    <Label fx:id="bidResultLabel" text="" wrapText="true"
                           style="-fx-font-size: 12;"/>
                </VBox>
            </VBox>

            <!-- Phải: lịch sử bid -->
            <VBox spacing="12"
                  style="-fx-background-color: white; -fx-padding: 24;
                         -fx-border-radius: 8; -fx-background-radius: 8;">
                <Label text="Lịch sử đặt giá"
                       style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                <Separator/>
                <ListView fx:id="bidHistoryList" 
                          style="-fx-background-color: transparent;"/>
            </VBox>
        </HBox>
    </center>

    <!-- Status bar -->
    <bottom>
        <HBox style="-fx-background-color: #ecf0f1; -fx-padding: 8 16;">
            <Label fx:id="statusLabel" text="Đang kết nối..."
                   style="-fx-font-size: 12; -fx-text-fill: #7f8c8d;"/>
        </HBox>
    </bottom>
</BorderPane>
