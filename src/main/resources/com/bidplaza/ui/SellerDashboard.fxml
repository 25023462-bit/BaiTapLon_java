<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.bidplaza.ui.controller.SellerDashboardController"
           stylesheets="@../../../css/bidder.css"
           style="-fx-background-color: #050816;">

    <!-- BACKGROUND -->
    <Pane styleClass="background-overlay"
          mouseTransparent="true"/>

    <!-- MAIN -->
    <BorderPane style="-fx-background-color: transparent;">

        <!-- TOP -->
        <top>

            <HBox alignment="CENTER_LEFT"
                  spacing="18"
                  prefHeight="80"
                  style="
                        -fx-background-color: rgba(10,10,35,0.72);
                        -fx-padding: 0 25 0 25;
                        -fx-border-color: #ff00ff;
                        -fx-border-width: 0 0 2 0;
                  ">

                <Label text="⚡ BIDPLAZA SELLER"
                       style="
                            -fx-text-fill: #ff00ff;
                            -fx-font-size: 28;
                            -fx-font-weight: bold;
                       "/>

                <Region HBox.hgrow="ALWAYS"/>

                <Label fx:id="userLabel"
                       text="SELLER"
                       style="
                            -fx-text-fill: white;
                            -fx-font-size: 15;
                            -fx-font-weight: bold;
                       "/>

                <Button text="LOGOUT"
                        onAction="#handleLogout"
                        styleClass="remove-button"/>

            </HBox>

        </top>

        <!-- CENTER -->
        <center>

            <HBox spacing="24"
                  fillHeight="true"
                  style="-fx-padding: 25;">



                <!-- CONTENT -->
                <VBox spacing="24"
                      HBox.hgrow="ALWAYS">

                    <!-- STATS -->
                    <HBox spacing="20">

                        <VBox HBox.hgrow="ALWAYS"
                              minHeight="120"
                              styleClass="watchlist-card">

                            <Label text="TOTAL AUCTIONS"
                                   style="
                                        -fx-text-fill: #8ea6ff;
                                        -fx-font-size: 14;
                                   "/>

                            <Label fx:id="totalAuctionsLabel" text="0"
                                   style="
                                        -fx-text-fill: white;
                                        -fx-font-size: 34;
                                        -fx-font-weight: bold;
                                   "/>

                        </VBox>

                        <VBox HBox.hgrow="ALWAYS"
                              minHeight="120"
                              styleClass="watchlist-card">

                            <Label text="ACTIVE"
                                   style="
                                        -fx-text-fill: #8ea6ff;
                                        -fx-font-size: 14;
                                   "/>

                            <Label fx:id="activeAuctionsLabel" text="0"
                                   style="
                                        -fx-text-fill: #00ff99;
                                        -fx-font-size: 34;
                                        -fx-font-weight: bold;
                                   "/>

                        </VBox>

                        <VBox HBox.hgrow="ALWAYS"
                              minHeight="120"
                              styleClass="watchlist-card">

                            <Label text="REVENUE"
                                   style="
                                        -fx-text-fill: #8ea6ff;
                                        -fx-font-size: 14;
                                   "/>

                            <Label fx:id="revenueLabel" text="0 USD"
                                   style="
                                        -fx-text-fill: #ff00ff;
                                        -fx-font-size: 34;
                                        -fx-font-weight: bold;
                                   "/>

                        </VBox>

                    </HBox>

                    <!-- MAIN BODY -->
                    <HBox spacing="24"
                          VBox.vgrow="ALWAYS">

                        <!-- FORM -->
                        <VBox fx:id="createFormPanel"
                              spacing="14"
                              prefWidth="520"
                              minWidth="420"
                              styleClass="watchlist-card">

                            <Label text="CREATE AUCTION"
                                   style="
                                        -fx-text-fill: white;
                                        -fx-font-size: 24;
                                        -fx-font-weight: bold;
                                   "/>

                            <Separator/>

                            <Label text="Item Name"
                                   style="-fx-text-fill: white;"/>

                            <TextField fx:id="itemNameField"
                                       promptText="Gaming Laptop..."
                                       styleClass="cyber-input"/>

                            <Label text="Category"
                                   style="-fx-text-fill: white;"/>

                            <ComboBox fx:id="categoryCombo"
                                      styleClass="cyber-input"/>

                            <Label text="Description"
                                   style="-fx-text-fill: white;"/>

                            <TextArea fx:id="descField"
                                      prefRowCount="4"
                                      promptText="Auction details..."
                                      styleClass="cyber-area"/>

                            <Label text="Starting Price"
                                   style="-fx-text-fill: white;"/>

                            <TextField fx:id="startPriceField"
                                       promptText="0.00 USD"
                                       styleClass="cyber-input"/>

                            <Label text="Duration (Hours)"
                                   style="-fx-text-fill: white;"/>

                            <Spinner fx:id="durationSpinner"
                                     min="1" max="168" initialValue="24"/>

                            <Label fx:id="formResultLabel"
                                   style="-fx-text-fill: #00ff99;"/>

                            <Region VBox.vgrow="ALWAYS"/>

                            <Button text="⚡ PUBLISH AUCTION"
                                    prefHeight="46"
                                    maxWidth="Infinity"
                                    onAction="#handleAddItem"
                                    styleClass="cyber-button"/>

                        </VBox>

                        <!-- TABLE -->
                        <VBox fx:id="auctionsTablePanel"
                              spacing="14"
                              VBox.vgrow="ALWAYS"
                              HBox.hgrow="ALWAYS"
                              styleClass="watchlist-card">

                            <HBox alignment="CENTER_LEFT">

                                <Label text="LIVE AUCTIONS"
                                       style="
                                            -fx-text-fill: white;
                                            -fx-font-size: 24;
                                            -fx-font-weight: bold;
                                       "/>

                                <Region HBox.hgrow="ALWAYS"/>

                                <Button text="REFRESH"
                                        onAction="#handleRefresh"
                                        styleClass="cyber-button"/>

                            </HBox>

                            <Separator/>

                            <TableView fx:id="itemTable"
                                       VBox.vgrow="ALWAYS">

                                <columns>

                                    <TableColumn fx:id="colName"
                                                 text="Item"/>

                                    <TableColumn fx:id="colCategory"
                                                 text="Category"/>

                                    <TableColumn fx:id="colPrice"
                                                 text="Start"/>

                                    <TableColumn fx:id="colStatus"
                                                 text="Status"/>

                                    <TableColumn fx:id="colBids"
                                                 text="End Time"/>

                                </columns>

                            </TableView>

                            <HBox alignment="CENTER_RIGHT">

                                <Button text="END AUCTION"
                                        onAction="#handleFinishAuction"
                                        styleClass="remove-button"/>

                            </HBox>

                        </VBox>

                    </HBox>

                </VBox>

            </HBox>

        </center>

    </BorderPane>

</StackPane>