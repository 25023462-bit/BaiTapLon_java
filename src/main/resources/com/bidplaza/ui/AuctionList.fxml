<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.openjfx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.bidplaza.ui.controller.AuctionListController"

            style="
                -fx-background-color: linear-gradient(
                    to bottom right,
                    #050816,
                    #0a1931,
                    #091540
                );
            ">

    <!-- HEADER -->
    <top>

        <HBox alignment="CENTER_LEFT"
              spacing="16"

              style="
                  -fx-background-color: rgba(5,5,30,0.95);
                  -fx-padding: 16;
                  -fx-border-color: #00e5ff;
                  -fx-border-width: 0 0 2 0;
              ">

            <!-- BACK -->
            <Button text="← BACK"
                    onAction="#handleBack"

                    style="
                        -fx-background-color: #16213e;
                        -fx-text-fill: #00e5ff;
                        -fx-font-weight: bold;
                        -fx-font-size: 13;
                        -fx-background-radius: 8;
                        -fx-border-color: #00e5ff;
                        -fx-border-radius: 8;
                        -fx-cursor: hand;
                        -fx-padding: 8 18;
                    "/>

            <!-- LOGO -->
            <Label text="BIDPLAZA"

                   style="
                       -fx-font-size: 24;
                       -fx-font-weight: bold;
                       -fx-text-fill: #00e5ff;
                   "/>

            <Label text="LIVE AUCTIONS"

                   style="
                       -fx-font-size: 14;
                       -fx-text-fill: #ff00ff;
                       -fx-font-weight: bold;
                   "/>

            <HBox HBox.hgrow="ALWAYS"/>

            <!-- USER -->
            <Label fx:id="userLabel"

                   style="
                       -fx-text-fill: white;
                       -fx-font-size: 14;
                   "/>

            <!-- LOGOUT -->
            <Button text="LOGOUT"
                    onAction="#handleLogout"

                    style="
                        -fx-background-color: #ff006e;
                        -fx-text-fill: white;
                        -fx-font-weight: bold;
                        -fx-background-radius: 8;
                        -fx-cursor: hand;
                        -fx-padding: 8 18;
                    "/>

        </HBox>

    </top>

    <!-- CENTER -->
    <center>

        <VBox spacing="20">

            <padding>
                <Insets top="25"
                        right="30"
                        bottom="25"
                        left="30"/>
            </padding>


            <!-- SEARCH -->
            <HBox spacing="12" alignment="CENTER_LEFT">

                <TextField fx:id="searchField"
                           promptText="Search auction..."
                           prefWidth="320"
                           style="
                   -fx-background-color: rgba(15,15,40,0.92);
                   -fx-text-fill: white;
                   -fx-prompt-text-fill: #bbbbbb;
                   -fx-border-color: #00e5ff;
                   -fx-border-radius: 10;
                   -fx-background-radius: 10;
                   -fx-padding: 10;
                   -fx-font-size: 14;
               "/>

                <ComboBox fx:id="categoryFilter"
                          promptText="Category"
                          prefWidth="150"/>

                <ComboBox fx:id="statusFilter"
                          promptText="Status"
                          prefWidth="130"/>

                <Button text="REFRESH"
                        onAction="#handleRefresh"
                        style="
                -fx-background-color: #00b4ff;
                -fx-text-fill: white;
                -fx-font-weight: bold;
                -fx-background-radius: 10;
                -fx-cursor: hand;
                -fx-padding: 10 22;
            "/>

                <Button text="CLEAR"
                        onAction="#handleClearFilter"
                        style="
                -fx-background-color: #ff006e;
                -fx-text-fill: white;
                -fx-font-weight: bold;
                -fx-background-radius: 10;
                -fx-cursor: hand;
                -fx-padding: 10 22;
            "/>

            </HBox>


            <!-- TABLE -->
            <StackPane VBox.vgrow="ALWAYS"

                       style="
                           -fx-background-color: rgba(10,20,45,0.85);
                           -fx-background-radius: 20;
                           -fx-border-color: #00e5ff;
                           -fx-border-radius: 20;
                           -fx-padding: 20;
                       ">

                <TableView fx:id="auctionTable"

                           style="
                               -fx-background-color: transparent;
                               -fx-control-inner-background: rgba(20,30,60,0.92);
                               -fx-table-cell-border-color: transparent;
                               -fx-text-background-color: white;
                               -fx-font-size: 14;
                           ">

                    <columns>

                        <TableColumn fx:id="colName"
                                     text="ITEM"
                                     prefWidth="240"/>

                        <TableColumn fx:id="colCategory"
                                     text="CATEGORY"
                                     prefWidth="140"/>

                        <TableColumn fx:id="colStartPrice"
                                     text="START PRICE"
                                     prefWidth="150"/>

                        <TableColumn fx:id="colCurrentPrice"
                                     text="CURRENT BID"
                                     prefWidth="150"/>

                        <TableColumn fx:id="colStatus"
                                     text="LIVE STATUS"
                                     prefWidth="180"/>

                        <TableColumn fx:id="colEndTime"
                                     text="END TIME"
                                     prefWidth="220"/>

                    </columns>

                    <placeholder>

                        <Label text="NO LIVE AUCTIONS"

                               style="
                                   -fx-text-fill: #bbbbbb;
                                   -fx-font-size: 16;
                               "/>

                    </placeholder>

                </TableView>

            </StackPane>

            <!-- JOIN -->
            <HBox alignment="CENTER_RIGHT">

                <Button text="JOIN AUCTION →"
                        onAction="#handleJoinAuction"

                        style="
                            -fx-background-color: #00e5ff;
                            -fx-text-fill: #081120;
                            -fx-font-weight: bold;
                            -fx-font-size: 14;
                            -fx-background-radius: 12;
                            -fx-cursor: hand;
                            -fx-padding: 12 24;
                        "/>

            </HBox>

        </VBox>

    </center>

</BorderPane>