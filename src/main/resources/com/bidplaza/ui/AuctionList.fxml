<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.openjfx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.bidplaza.ui.controller.AuctionListController"
            style="-fx-background-color: #f0f4f8;">

    <!-- Header -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color: #2c3e50; -fx-padding: 16;">
            <Label text="BidPlaza" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label text="Danh sách đấu giá" style="-fx-font-size: 14; -fx-text-fill: #bdc3c7;"/>
            <HBox HBox.hgrow="ALWAYS"/>
            <Label fx:id="userLabel" style="-fx-text-fill: #ecf0f1; -fx-font-size: 13;"/>
            <Button text="Đăng xuất" onAction="#handleLogout"
                    style="-fx-background-color: #e74c3c; -fx-text-fill: white;
                           -fx-border-radius: 4; -fx-background-radius: 4; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <!-- Nội dung chính -->
    <center>
        <VBox spacing="12">
            <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>

            <!-- Thanh tìm kiếm -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="searchField" promptText="Tìm kiếm sản phẩm..."
                           prefWidth="300" style="-fx-padding: 8; -fx-border-radius: 4; -fx-background-radius: 4;"/>
                <Button text="Làm mới" onAction="#handleRefresh"
                        style="-fx-background-color: #3498db; -fx-text-fill: white;
                               -fx-border-radius: 4; -fx-background-radius: 4; -fx-cursor: hand; -fx-padding: 8 16;"/>
            </HBox>

            <!-- Bảng danh sách phiên đấu giá -->
            <TableView fx:id="auctionTable" VBox.vgrow="ALWAYS"
                       style="-fx-background-color: white; -fx-border-radius: 8; -fx-background-radius: 8;">
                <columns>
                    <TableColumn fx:id="colName" text="Sản phẩm" prefWidth="220"/>
                    <TableColumn fx:id="colCategory" text="Loại" prefWidth="100"/>
                    <TableColumn fx:id="colStartPrice" text="Giá khởi điểm" prefWidth="130"/>
                    <TableColumn fx:id="colCurrentPrice" text="Giá hiện tại" prefWidth="130"/>
                    <TableColumn fx:id="colStatus" text="Trạng thái" prefWidth="110"/>
                    <TableColumn fx:id="colEndTime" text="Kết thúc lúc" prefWidth="160"/>
                </columns>
                <placeholder>
                    <Label text="Chưa có phiên đấu giá nào" style="-fx-text-fill: #95a5a6;"/>
                </placeholder>
            </TableView>

            <!-- Nút tham gia -->
            <HBox alignment="CENTER_RIGHT">
                <Button text="Tham gia đấu giá →" onAction="#handleJoinAuction"
                        style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;
                               -fx-border-radius: 6; -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 10 20;"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>
