<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.bidplaza.ui.controller.LoginController">

    <children>

        <!-- Background -->
        <AnchorPane prefWidth="1200"
                    prefHeight="700"
                    style="-fx-background-image: url('/images/register-bg.png');
                           -fx-background-size: cover;
                           -fx-background-position: center;">

            <!-- Dark Overlay -->
            <Pane prefWidth="1200"
                  prefHeight="700"
                  style="-fx-background-color: rgba(0,0,0,0.25);" />

            <!-- Main Layout -->
            <HBox prefWidth="1200"
                  prefHeight="700"
                  alignment="CENTER_LEFT"
                  spacing="120"
                  AnchorPane.topAnchor="0"
                  AnchorPane.bottomAnchor="0"
                  AnchorPane.leftAnchor="0"
                  AnchorPane.rightAnchor="0">

                <padding>
                    <Insets top="0" right="80" bottom="0" left="80"/>
                </padding>

                <!-- LOGIN CARD -->
                <VBox spacing="16"
                      alignment="CENTER_LEFT"
                      maxWidth="480"
                      prefWidth="480"
                      style="-fx-background-color: rgba(8,18,40,0.35);
                             -fx-background-radius: 30;
                             -fx-border-color: rgba(0,245,255,0.25);
                             -fx-border-radius: 30;
                             -fx-padding: 50;
                             -fx-effect: dropshadow(gaussian, rgba(0,245,255,0.35), 40, 0.3, 0, 0);">

                    <!-- LOGO -->
                    <VBox spacing="6">

                        <Label text="⚖"
                               style="-fx-font-size: 50px;
                                      -fx-text-fill: #00f5ff;" />

                        <Label text="BIDPLAZA"
                               style="-fx-font-size: 38px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #00f5ff;" />

                        <Label text="REAL-TIME AUCTION PLATFORM"
                               style="-fx-font-size: 11px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #8be9fd;" />

                    </VBox>

                    <Region prefHeight="15"/>

                    <Label text="WELCOME BACK"
                           style="-fx-font-size: 32px;
                      -fx-font-weight: bold;
                      -fx-text-fill: white;" />

                    <Label text="Sign in to continue your auction journey"
                           style="-fx-font-size: 14px;
                      -fx-text-fill: #cfd8dc;" />

                    <!-- USERNAME -->
                    <VBox spacing="8">

                        <Label text="Username"
                               style="-fx-font-size: 15px;
                          -fx-font-weight: bold;
                          -fx-text-fill: white;" />

                        <TextField fx:id="usernameField"
                                   promptText="Enter username"
                                   prefWidth="320"
                                   prefHeight="46"
                                   style="-fx-background-color: rgba(0,0,0,0.35);
                              -fx-border-color: #00eaff;
                              -fx-border-radius: 12;
                              -fx-background-radius: 12;
                              -fx-text-fill: white;
                              -fx-prompt-text-fill: #95a5a6;
                              -fx-padding: 12;
                              -fx-font-size: 14px;" />
                    </VBox>

                    <!-- PASSWORD -->
                    <VBox spacing="8">

                        <Label text="Password"
                               style="-fx-font-size: 15px;
                          -fx-font-weight: bold;
                          -fx-text-fill: white;" />

                        <PasswordField fx:id="passwordField"
                                       promptText="Enter password"
                                       prefWidth="320"
                                       prefHeight="46"
                                       style="-fx-background-color: rgba(0,0,0,0.35);
                                  -fx-border-color: #00eaff;
                                  -fx-border-radius: 12;
                                  -fx-background-radius: 12;
                                  -fx-text-fill: white;
                                  -fx-prompt-text-fill: #95a5a6;
                                  -fx-padding: 12;
                                  -fx-font-size: 14px;" />
                    </VBox>

                    <!-- ROLE -->
                    <VBox spacing="8">

                        <Label text="Role"
                               style="-fx-font-size: 15px;
                          -fx-font-weight: bold;
                          -fx-text-fill: white;" />

                        <ComboBox fx:id="roleCombo"
                                  prefWidth="320"
                                  prefHeight="46"
                                  style="-fx-background-color: rgba(0,0,0,0.35);
                             -fx-border-color: #00eaff;
                             -fx-border-radius: 12;
                             -fx-background-radius: 12;
                             -fx-font-size: 14px;" />
                    </VBox>

                    <!-- ERROR -->
                    <Label fx:id="errorLabel"
                           text=""
                           style="-fx-font-size: 13px;
                      -fx-text-fill: #ff7675;" />

                    <!-- LOGIN -->
                    <Button fx:id="loginButton"
                            text="LOGIN"
                            prefWidth="320"
                            prefHeight="48"
                            onAction="#handleLogin"
                            style="-fx-background-color: linear-gradient(to right,#00f5ff,#00a8ff);
                       -fx-text-fill: white;
                       -fx-font-size: 16px;
                       -fx-font-weight: bold;
                       -fx-background-radius: 14;
                       -fx-cursor: hand;" />

                    <!-- REGISTER -->
                    <Button text="CREATE ACCOUNT"
                            prefWidth="320"
                            prefHeight="48"
                            onAction="#openRegister"
                            style="-fx-background-color: transparent;
                       -fx-text-fill: #00f5ff;
                       -fx-font-size: 15px;
                       -fx-font-weight: bold;
                       -fx-border-color: #00f5ff;
                       -fx-border-width: 1.5;
                       -fx-border-radius: 14;
                       -fx-background-radius: 14;
                       -fx-cursor: hand;" />

                </VBox>

                <!-- RIGHT SIDE CONTENT -->
                <Region HBox.hgrow="ALWAYS"/>

            </HBox>
        </AnchorPane>

    </children>

</StackPane>