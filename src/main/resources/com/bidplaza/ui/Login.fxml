<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.bidplaza.ui.controller.LoginController">

    <children>

        <!-- Background -->
        <AnchorPane prefWidth="1200"
                    prefHeight="700"
                    style="-fx-background-image: url('/images/login-bg.png');
                           -fx-background-size: cover;
                           -fx-background-position: center;">

            <!-- Dark Overlay -->
            <Pane prefWidth="1200"
                  prefHeight="700"
                  style="-fx-background-color: rgba(0,0,0,0.55);" />

            <!-- Main Layout -->
            <HBox prefWidth="1200"
                  prefHeight="700"
                  alignment="CENTER_LEFT"
                  spacing="120"
                  AnchorPane.topAnchor="0"
                  AnchorPane.bottomAnchor="0"
                  AnchorPane.leftAnchor="0"
                  AnchorPane.rightAnchor="0">

                <padding>
                    <Insets top="0" right="80" bottom="0" left="80"/>
                </padding>

                <!-- Login Card -->
                <VBox spacing="16"
                      alignment="CENTER_LEFT"
                      maxWidth="380"
                      prefWidth="380"
                      style="-fx-background-color: rgba(255,255,255,0.96);
                             -fx-background-radius: 22;
                             -fx-padding: 35;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 25, 0.2, 0, 10);">

                    <!-- Title -->
                    <Label text="BidPlaza"
                           style="-fx-font-size: 32px;
                                  -fx-font-weight: bold;
                                  -fx-text-fill: #2d3436;" />

                    <Label text="Login to continue bidding"
                           style="-fx-font-size: 14px;
                                  -fx-text-fill: #636e72;" />

                    <!-- Username -->
                    <VBox spacing="7">
                        <Label text="Username"
                               style="-fx-font-weight: bold;
                                      -fx-text-fill: #2d3436;" />

                        <TextField fx:id="usernameField"
                                   promptText="Enter username"
                                   prefWidth="300"
                                   prefHeight="42"
                                   style="-fx-background-radius: 10;
                                          -fx-border-radius: 10;
                                          -fx-padding: 10;
                                          -fx-font-size: 14px;" />
                    </VBox>

                    <!-- Password -->
                    <VBox spacing="7">
                        <Label text="Password"
                               style="-fx-font-weight: bold;
                                      -fx-text-fill: #2d3436;" />

                        <PasswordField fx:id="passwordField"
                                       promptText="Enter password"
                                       prefWidth="300"
                                       prefHeight="42"
                                       style="-fx-background-radius: 10;
                                              -fx-border-radius: 10;
                                              -fx-padding: 10;
                                              -fx-font-size: 14px;" />
                    </VBox>

                    <!-- Role -->
                    <VBox spacing="7">
                        <Label text="Role"
                               style="-fx-font-weight: bold;
                                      -fx-text-fill: #2d3436;" />

                        <ComboBox fx:id="roleCombo"
                                  prefWidth="300"
                                  prefHeight="42"
                                  style="-fx-background-radius: 10;
                                         -fx-border-radius: 10;
                                         -fx-font-size: 14px;" />
                    </VBox>

                    <!-- Error -->
                    <Label fx:id="errorLabel"
                           text=""
                           style="-fx-text-fill: #e74c3c;
                                  -fx-font-size: 13px;" />

                    <!-- Button -->
                    <Button text="LOGIN"
                            prefWidth="300"
                            prefHeight="45"
                            onAction="#handleLogin"
                            style="-fx-background-color: linear-gradient(to right, #00b894, #00cec9);
                                   -fx-text-fill: white;
                                   -fx-font-size: 15px;
                                   -fx-font-weight: bold;
                                   -fx-background-radius: 12;
                                   -fx-cursor: hand;" />

                </VBox>

                <!-- Right Side Text -->
                <VBox spacing="18"
                      alignment="CENTER_LEFT">

                    <Label text="Online Auction Platform"
                           style="-fx-font-size: 54px;
                                  -fx-font-weight: bold;
                                  -fx-text-fill: white;" />

                    <Label text="Bid smarter. Win faster. Experience modern online auctions with BidPlaza."
                           wrapText="true"
                           maxWidth="420"
                           style="-fx-font-size: 18px;
                                  -fx-text-fill: #dfe6e9;" />

                </VBox>

            </HBox>

        </AnchorPane>

    </children>

</StackPane>