<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.bidplaza.ui.controller.BidderDashboardController">

    <AnchorPane prefWidth="1500"
                prefHeight="850"
                style="
                    -fx-background-image: url('/images/cyber-bg.png');
                    -fx-background-size: cover;
                    -fx-background-position: center;
                ">

        <!-- TOP BAR -->

        <HBox layoutX="250"
              layoutY="20"

              prefWidth="1120"
              prefHeight="45"

              alignment="CENTER_LEFT"

              spacing="30"

              style="
                -fx-background-color: rgba(10,10,35,0.75);

                -fx-background-radius: 20;

                -fx-border-color: #00e5ff;

                -fx-border-radius: 20;

                -fx-padding: 10 25 10 25;
              ">

            <Label text="BIDPLAZA"
                   style="
                    -fx-text-fill: #00e5ff;
                    -fx-font-size: 24;
                    -fx-font-weight: bold;
                   "/>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- WELCOME LABEL -->

            <Label fx:id="welcomeLabel"
                   text="WELCOME BIDDER"
                   style="
                    -fx-text-fill: white;
                    -fx-font-size: 16;
                   "/>

        </HBox>

        <!-- SIDEBAR -->

        <VBox layoutX="25"
              layoutY="70"

              prefWidth="180"
              prefHeight="680"

              alignment="TOP_CENTER"

              spacing="30"

              style="
                -fx-background-color: rgba(10,10,30,0.78);

                -fx-background-radius: 25;

                -fx-border-color: #7a00ff;

                -fx-border-width: 2;

                -fx-border-radius: 25;

                -fx-padding: 30;

                -fx-effect: dropshadow(
                    gaussian,
                    #7a00ff,
                    25,
                    0.5,
                    0,
                    0
                );
              ">

            <Label text="BIDDER"
                   style="
                    -fx-text-fill: white;
                    -fx-font-size: 24;
                    -fx-font-weight: bold;
                   "/>

            <Button text="AUCTIONS"
                    onAction="#openAuctions"
                    prefWidth="140"
                    prefHeight="45"/>

            <Button text="MY BIDS"
                    onAction="#openMyBids"
                    prefWidth="140"
                    prefHeight="45"/>

            <Button text="WATCHLIST"
                    onAction="#openWatchlist"
                    prefWidth="140"
                    prefHeight="45"/>

            <Button text="HISTORY"
                    onAction="#openHistory"
                    prefWidth="140"
                    prefHeight="45"/>

            <Button text="PROFILE"
                    onAction="#openProfile"
                    prefWidth="140"
                    prefHeight="45"/>

            <Button text="LOGOUT"
                    onAction="#handleLogout"
                    prefWidth="140"
                    prefHeight="45"/>

        </VBox>

        <!-- MAIN FRAME -->

        <Pane layoutX="250"
              layoutY="90"

              prefWidth="820"
              prefHeight="560"

              style="
                -fx-background-color: rgba(0,0,20,0.18);

                -fx-border-color: #00e5ff;

                -fx-border-width: 3;

                -fx-border-radius: 20;

                -fx-background-radius: 20;

                -fx-effect: dropshadow(
                    gaussian,
                    #00e5ff,
                    25,
                    0.7,
                    0,
                    0
                );
              ">

            <!-- TITLE -->

            <Label layoutX="30"
                   layoutY="25"

                   text="LIVE AUCTIONS"

                   style="
                    -fx-text-fill: white;
                    -fx-font-size: 28;
                    -fx-font-weight: bold;
                   "/>

            <!-- AUCTION CARDS -->

            <VBox layoutX="35"
                  layoutY="90"

                  spacing="25">

                <!-- CARD 1 -->

                <HBox spacing="25"

                      prefWidth="720"
                      prefHeight="120"

                      style="
                        -fx-background-color: rgba(20,20,45,0.82);

                        -fx-background-radius: 20;

                        -fx-border-color: #00e5ff;

                        -fx-border-radius: 20;

                        -fx-padding: 20;
                       ">

                    <VBox spacing="12">

                        <Label text="CYBER CAR"
                               style="
                                -fx-text-fill: white;
                                -fx-font-size: 24;
                                -fx-font-weight: bold;
                               "/>

                        <Label text="Current Bid: 12,450 USD"
                               style="
                                -fx-text-fill: #00e5ff;
                                -fx-font-size: 16;
                               "/>

                        <Label text="Time Left: 00:05:32"
                               style="
                                -fx-text-fill: #ff4dff;
                                -fx-font-size: 16;
                               "/>

                    </VBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Button text="BID NOW"

                            prefWidth="140"
                            prefHeight="45"

                            style="
                              -fx-background-color: rgba(0,229,255,0.15);

                              -fx-border-color: #00e5ff;

                              -fx-border-radius: 15;

                              -fx-background-radius: 15;
                            "/>

                </HBox>

                <!-- CARD 2 -->

                <HBox spacing="25"

                      prefWidth="720"
                      prefHeight="120"

                      style="
                        -fx-background-color: rgba(20,20,45,0.82);

                        -fx-background-radius: 20;

                        -fx-border-color: #ff00ff;

                        -fx-border-radius: 20;

                        -fx-padding: 20;
                       ">

                    <VBox spacing="12">

                        <Label text="NEON BIKE"
                               style="
                                -fx-text-fill: white;
                                -fx-font-size: 24;
                                -fx-font-weight: bold;
                               "/>

                        <Label text="Current Bid: 8,200 USD"
                               style="
                                -fx-text-fill: #00e5ff;
                                -fx-font-size: 16;
                               "/>

                        <Label text="Time Left: 00:12:45"
                               style="
                                -fx-text-fill: #ff4dff;
                                -fx-font-size: 16;
                               "/>

                    </VBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Button text="BID NOW"

                            prefWidth="140"
                            prefHeight="45"

                            style="
                              -fx-background-color: rgba(255,0,255,0.12);

                              -fx-border-color: #ff00ff;

                              -fx-border-radius: 15;

                              -fx-background-radius: 15;
                            "/>

                </HBox>

            </VBox>

        </Pane>

        <!-- RIGHT PANEL -->

        <VBox layoutX="1100"
              layoutY="90"

              prefWidth="260"
              prefHeight="340"

              spacing="20"

              style="
                -fx-background-color: rgba(20,0,40,0.82);

                -fx-border-color: #ff00ff;

                -fx-border-width: 2;

                -fx-border-radius: 20;

                -fx-background-radius: 20;

                -fx-padding: 25;

                -fx-effect: dropshadow(
                    gaussian,
                    #ff00ff,
                    25,
                    0.7,
                    0,
                    0
                );
              ">

            <Label text="LIVE AUCTION"
                   style="
                    -fx-text-fill: #ff4dff;
                    -fx-font-size: 24;
                    -fx-font-weight: bold;
                   "/>

            <Separator/>

            <Label text="CURRENT BID"
                   style="
                    -fx-text-fill: white;
                    -fx-font-size: 15;
                   "/>

            <Label text="12,450 USD"
                   style="
                    -fx-text-fill: white;
                    -fx-font-size: 38;
                    -fx-font-weight: bold;
                   "/>

            <Separator/>

            <Label text="TIME LEFT"
                   style="
                    -fx-text-fill: white;
                    -fx-font-size: 15;
                   "/>

            <Label text="00:05:32"
                   style="
                    -fx-text-fill: #00e5ff;
                    -fx-font-size: 34;
                    -fx-font-weight: bold;
                   "/>

        </VBox>

    </AnchorPane>

</StackPane>