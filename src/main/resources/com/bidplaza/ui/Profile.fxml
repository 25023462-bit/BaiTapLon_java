<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.openjfx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:id="rootPane"
            fx:controller="com.bidplaza.ui.controller.ProfileController"
            stylesheets="@style.css">

    <center>

        <AnchorPane styleClass="profile-background">

            <VBox spacing="25"
                  AnchorPane.topAnchor="35"
                  AnchorPane.leftAnchor="40"
                  AnchorPane.rightAnchor="40"
                  AnchorPane.bottomAnchor="35">

                <!-- TITLE -->

                <Label text="THÔNG TIN CÁ NHÂN"
                       styleClass="profile-title"/>

                <!-- TOP SECTION -->

                <HBox spacing="30">

                    <!-- PROFILE CARD -->

                    <VBox spacing="16"
                          prefWidth="500"
                          styleClass="neon-card">

                        <Label text="THÔNG TIN CÁ NHÂN"
                               styleClass="card-title"/>

                        <VBox spacing="8">

                            <Label text="Username"
                                   styleClass="field-label"/>

                            <Label fx:id="usernameLabel"
                                   text="-"
                                   styleClass="field-value"/>

                        </VBox>

                        <VBox spacing="8">

                            <Label text="Email"
                                   styleClass="field-label"/>

                            <Label fx:id="emailLabel"
                                   text="-"
                                   styleClass="field-value"/>

                        </VBox>

                        <VBox spacing="8">

                            <Label text="Vai trò"
                                   styleClass="field-label"/>

                            <Label fx:id="roleLabel"
                                   text="-"
                                   styleClass="role-value"/>

                        </VBox>

                    </VBox>

                    <!-- STATS CARD -->

                    <VBox spacing="20"
                          prefWidth="420"
                          styleClass="neon-card">

                        <Label text="THỐNG KÊ BIDDER"
                               styleClass="card-title"/>

                        <HBox spacing="10">

                            <Label text="Số dư:"
                                   styleClass="stat-label"/>

                            <Label fx:id="stat1Label"
                                   text="-"
                                   styleClass="money-value"/>

                        </HBox>

                        <HBox spacing="10">

                            <Label text="Tổng bid:"
                                   styleClass="stat-label"/>

                            <Label fx:id="stat2Label"
                                   text="-"
                                   styleClass="cyan-value"/>

                        </HBox>

                        <HBox spacing="10">

                            <Label text="Phiên thắng:"
                                   styleClass="stat-label"/>

                            <Label fx:id="stat3Label"
                                   text="-"
                                   styleClass="pink-value"/>

                        </HBox>

                    </VBox>

                </HBox>

                <!-- PASSWORD BOX -->

                <VBox spacing="18"
                      styleClass="password-box">

                    <Label text="ĐỔI MẬT KHẨU"
                           styleClass="card-title"/>

                    <PasswordField fx:id="oldPasswordField"
                                   promptText="Mật khẩu cũ"
                                   styleClass="cyber-input"/>

                    <PasswordField fx:id="newPasswordField"
                                   promptText="Mật khẩu mới"
                                   styleClass="cyber-input"/>

                    <Button text="XÁC NHẬN"
                            onAction="#handleChangePassword"
                            styleClass="cyber-button"/>

                    <Label fx:id="passwordResultLabel"
                           style="-fx-text-fill: #00ffff;" />

                </VBox>

                <!-- BACK BUTTON -->

                <HBox>

                    <Button text="← QUAY LẠI"
                            onAction="#handleBack"
                            styleClass="back-button"/>

                </HBox>

            </VBox>

        </AnchorPane>

    </center>

</BorderPane>