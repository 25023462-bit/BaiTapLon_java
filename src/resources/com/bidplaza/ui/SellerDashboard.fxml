<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.openjfx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.bidplaza.ui.controller.SellerDashboardController"
            style="-fx-background-color: #f0f4f8;">

    <!-- Header -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color: #8e44ad; -fx-padding: 16;">
            <Label text="BidPlaza" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label text="Quản lý sản phẩm (Seller)" style="-fx-font-size: 14; -fx-text-fill: #d7bde2;"/>
            <HBox />
            <Label fx:id="userLabel" style="-fx-text-fill: white; -fx-font-size: 13;"/>
            <Button text="Đăng xuất" onAction="#handleLogout"
                    style="-fx-background-color: #e74c3c; -fx-text-fill: white;
                           -fx-border-radius: 4; -fx-background-radius: 4; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <center>
        <HBox spacing="20">
            <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>

            <!-- Trái: Form thêm sản phẩm -->
            <VBox spacing="14" prefWidth="320"
                  style="-fx-background-color: white; -fx-padding: 24;
                         -fx-border-radius: 8; -fx-background-radius: 8;">
                <Label text="Thêm sản phẩm mới"
                       style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                <Separator/>

                <Label text="Tên sản phẩm" style="-fx-font-weight: bold;"/>
                <TextField fx:id="itemNameField" promptText="Tên sản phẩm..."
                           style="-fx-padding: 8; -fx-border-radius: 4; -fx-background-radius: 4;"/>

                <Label text="Loại" style="-fx-font-weight: bold;"/>
                <ComboBox fx:id="categoryCombo" 
                          style="-fx-padding: 4; -fx-border-radius: 4; -fx-background-radius: 4;"/>

                <Label text="Mô tả" style="-fx-font-weight: bold;"/>
                <TextArea fx:id="descField" promptText="Mô tả sản phẩm..." prefRowCount="3"
                          style="-fx-border-radius: 4; -fx-background-radius: 4;"/>

                <Label text="Giá khởi điểm ($)" style="-fx-font-weight: bold;"/>
                <TextField fx:id="startPriceField" promptText="0.00"
                           style="-fx-padding: 8; -fx-border-radius: 4; -fx-background-radius: 4;"/>

                <Label text="Thời gian đấu giá (giờ)" style="-fx-font-weight: bold;"/>
                <Spinner fx:id="durationSpinner" min="1" max="72" initialValue="1" />

                <Label fx:id="formResultLabel" text="" wrapText="true" style="-fx-font-size: 12;"/>

                <Button text="Đăng sản phẩm đấu giá"  prefHeight="40"
                        onAction="#handleAddItem"
                        style="-fx-background-color: #8e44ad; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-border-radius: 6;
                               -fx-background-radius: 6; -fx-cursor: hand;"/>
            </VBox>

            <!-- Phải: Danh sách sản phẩm của Seller -->
            <VBox spacing="12" 
                  style="-fx-background-color: white; -fx-padding: 24;
                         -fx-border-radius: 8; -fx-background-radius: 8;">
                <Label text="Sản phẩm của bạn"
                       style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                <Separator/>

                <TableView fx:id="itemTable" >
                    <columns>
                        <TableColumn fx:id="colName" text="Tên" prefWidth="160"/>
                        <TableColumn fx:id="colCategory" text="Loại" prefWidth="100"/>
                        <TableColumn fx:id="colPrice" text="Giá KĐ" prefWidth="90"/>
                        <TableColumn fx:id="colStatus" text="Trạng thái" prefWidth="100"/>
                        <TableColumn fx:id="colBids" text="Số bid" prefWidth="70"/>
                    </columns>
                    <placeholder>
                        <Label text="Chưa có sản phẩm nào" style="-fx-text-fill: #95a5a6;"/>
                    </placeholder>
                </TableView>

                <HBox alignment="CENTER_RIGHT" spacing="10">
                    <Button text="Kết thúc phiên" onAction="#handleFinishAuction"
                            style="-fx-background-color: #e67e22; -fx-text-fill: white;
                                   -fx-border-radius: 4; -fx-background-radius: 4;
                                   -fx-cursor: hand; -fx-padding: 8 16;"/>
                </HBox>
            </VBox>
        </HBox>
    </center>
</BorderPane>
