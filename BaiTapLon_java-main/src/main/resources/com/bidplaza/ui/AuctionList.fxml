<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.openjfx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.bidplaza.ui.controller.AuctionListController"
            stylesheets="@../../../css/bidder.css"
            style="
                -fx-background-image: url('/images/cyber-bg.png');
                -fx-background-size: cover;
                -fx-background-position: center center;
                -fx-background-repeat: no-repeat;
            ">

    <!-- HEADER -->
    <top>

        <HBox alignment="CENTER_LEFT"
              spacing="18"
              prefHeight="86"
              styleClass="auctions-topbar">

            <!-- BACK -->
            <Button text="← BACK"
                    onAction="#handleBack"
                    styleClass="auctions-back"/>

            <!-- LOGO -->
            <Label text="BIDPLAZA"
                   styleClass="auctions-logo"/>

            <Label text="LIVE AUCTIONS"
                   styleClass="auctions-subtitle"/>

            <HBox HBox.hgrow="ALWAYS"/>

            <!-- USER -->
            <Label fx:id="userLabel"
                   styleClass="auctions-user"/>

            <!-- LOGOUT -->
            <Button text="LOGOUT"
                    onAction="#handleLogout"
                    styleClass="remove-button"/>

        </HBox>

    </top>

    <!-- CENTER -->
    <center>

        <VBox spacing="18">

            <padding>
                <Insets top="25"
                        right="30"
                        bottom="25"
                        left="30"/>
            </padding>


            <!-- SEARCH -->
            <HBox spacing="12" alignment="CENTER_LEFT" styleClass="auctions-toolbar">

                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="auctions-searchbox">
                    <Label text="🔍" styleClass="auctions-searchicon"/>
                    <TextField fx:id="searchField"
                               promptText="Search auction..."
                               prefWidth="360"
                               styleClass="auctions-searchfield"/>
                </HBox>

                <ComboBox fx:id="categoryFilter"
                          promptText="All Categories"
                          prefWidth="170"
                          styleClass="auctions-filter"/>

                <ComboBox fx:id="statusFilter"
                          promptText="All Status"
                          prefWidth="150"
                          styleClass="auctions-filter"/>

                <Button text="REFRESH"
                        onAction="#handleRefresh"
                        styleClass="cyber-button"/>

                <Button text="CLEAR"
                        onAction="#handleClearFilter"
                        styleClass="remove-button"/>

            </HBox>


            <!-- TABLE -->
            <StackPane VBox.vgrow="ALWAYS"
                       styleClass="auctions-tablewrap">

                <TableView fx:id="auctionTable"
                           styleClass="auctions-table">

                    <columns>

                        <TableColumn fx:id="colName"
                                     text="ITEM"
                                     prefWidth="240"/>

                        <TableColumn fx:id="colCategory"
                                     text="CATEGORY"
                                     prefWidth="140"/>

                        <TableColumn fx:id="colStartPrice"
                                     text="START PRICE"
                                     prefWidth="150"/>

                        <TableColumn fx:id="colCurrentPrice"
                                     text="CURRENT BID"
                                     prefWidth="150"/>

                        <TableColumn fx:id="colStatus"
                                     text="LIVE STATUS"
                                     prefWidth="180"/>

                        <TableColumn fx:id="colEndTime"
                                     text="END TIME"
                                     prefWidth="220"/>

                    </columns>

                    <placeholder>

                        <Label text="NO LIVE AUCTIONS"
                               styleClass="auctions-empty"/>

                    </placeholder>

                </TableView>

            </StackPane>

            <!-- JOIN -->
            <HBox alignment="CENTER_RIGHT">

                <Button text="JOIN AUCTION →"
                        onAction="#handleJoinAuction"
                        styleClass="auctions-join"/>

            </HBox>

        </VBox>

    </center>

</BorderPane>