<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.openjfx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.bidplaza.ui.controller.AdminDashboardController">

    <style>
        -fx-background-image: url('/images/cyber-bg.png');
        -fx-background-size: cover;
        -fx-background-position: center;
    </style>

    <top>
        <HBox alignment="CENTER_LEFT"
              spacing="20"
              style="
              -fx-background-color: rgba(5,5,35,0.92);
              -fx-border-color: #ff00ff;
              -fx-border-width: 0 0 2 0;
              -fx-padding: 18 25;
              ">

            <Label text="⚡ BIDPLAZA CONTROL CENTER"
                   style="
                   -fx-font-size: 30;
                   -fx-font-weight: bold;
                   -fx-text-fill: #ff00ff;
                   "/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label fx:id="userLabel"
                   style="
                   -fx-text-fill: white;
                   -fx-font-size: 14;
                   -fx-font-weight: bold;
                   "/>

            <Button text="⟳ REFRESH"
                    onAction="#handleRefresh"
                    style="
                    -fx-background-color: transparent;
                    -fx-border-color: #00e5ff;
                    -fx-border-radius: 12;
                    -fx-background-radius: 12;
                    -fx-text-fill: #00e5ff;
                    -fx-font-weight: bold;
                    "/>

            <Button text="⎋ LOGOUT"
                    onAction="#handleLogout"
                    style="
                    -fx-background-color: transparent;
                    -fx-border-color: #ff00ff;
                    -fx-border-radius: 12;
                    -fx-background-radius: 12;
                    -fx-text-fill: #ff00ff;
                    -fx-font-weight: bold;
                    "/>

        </HBox>
    </top>

    <center>
        <VBox spacing="20">

            <padding>
                <Insets top="20" right="25" bottom="20" left="25"/>
            </padding>

            <HBox spacing="15">

                <VBox alignment="CENTER"
                      prefWidth="180"
                      prefHeight="100"
                      style="
                      -fx-background-color: rgba(5,15,45,0.80);
                      -fx-border-color: #00e5ff;
                      -fx-border-radius: 20;
                      -fx-background-radius: 20;
                      ">

                    <Label text="TOTAL USERS"
                           style="
                           -fx-text-fill:#00e5ff;
                           -fx-font-weight:bold;
                           "/>

                    <Label fx:id="totalUsersLabel"
                           text="0"
                           style="
                           -fx-text-fill:white;
                           -fx-font-size:38;
                           -fx-font-weight:bold;
                           "/>

                </VBox>

                <VBox alignment="CENTER"
                      prefWidth="180"
                      prefHeight="100"
                      style="
                      -fx-background-color: rgba(5,15,45,0.80);
                      -fx-border-color: #00e5ff;
                      -fx-border-radius: 20;
                      -fx-background-radius: 20;
                      ">

                    <Label text="BIDDERS"
                           style="
                           -fx-text-fill:#00e5ff;
                           -fx-font-weight:bold;
                           "/>

                    <Label fx:id="totalBiddersLabel"
                           text="0"
                           style="
                           -fx-text-fill:white;
                           -fx-font-size:38;
                           -fx-font-weight:bold;
                           "/>

                </VBox>

                <VBox alignment="CENTER"
                      prefWidth="180"
                      prefHeight="100"
                      style="
                      -fx-background-color: rgba(5,15,45,0.80);
                      -fx-border-color: #00e5ff;
                      -fx-border-radius: 20;
                      -fx-background-radius: 20;
                      ">

                    <Label text="SELLERS"
                           style="
                           -fx-text-fill:#00e5ff;
                           -fx-font-weight:bold;
                           "/>

                    <Label fx:id="totalSellersLabel"
                           text="0"
                           style="
                           -fx-text-fill:white;
                           -fx-font-size:38;
                           -fx-font-weight:bold;
                           "/>

                </VBox>
                <VBox alignment="CENTER"
                      prefWidth="180"
                      prefHeight="100"
                      style="
                      -fx-background-color: rgba(5,15,45,0.80);
                      -fx-border-color: #00e5ff;
                      -fx-border-radius: 20;
                      -fx-background-radius: 20;
                      ">

                    <Label text="RUNNING"
                           style="
                           -fx-text-fill:#00e5ff;
                           -fx-font-weight:bold;
                           "/>

                    <Label fx:id="runningLabel"
                           text="0"
                           style="
                           -fx-text-fill:white;
                           -fx-font-size:38;
                           -fx-font-weight:bold;
                           "/>

                </VBox>
                <VBox alignment="CENTER"
                      prefWidth="220"
                      prefHeight="100"
                      style="
                      -fx-background-color: rgba(5,15,45,0.80);
                      -fx-border-color: #ff00ff;
                      -fx-border-radius: 20;
                      -fx-background-radius: 20;
                      ">

                    <Label text="TOTAL REVENUE"
                           style="
                           -fx-text-fill:#ff00ff;
                           -fx-font-weight:bold;
                           "/>

                    <Label fx:id="revenueLabel"
                           text="0.00"
                           style="
                           -fx-text-fill:white;
                           -fx-font-size:28;
                           -fx-font-weight:bold;
                           "/>

                </VBox>

            </HBox>

            <VBox spacing="12"
                  VBox.vgrow="ALWAYS"
                  style="
                  -fx-background-color: rgba(5,15,45,0.80);
                  -fx-border-color:#00e5ff;
                  -fx-border-radius:20;
                  -fx-background-radius:20;
                  -fx-padding:18;
                  ">

                <Label text="👥 USER MANAGEMENT"
                       style="
                       -fx-text-fill:#00e5ff;
                       -fx-font-size:18;
                       -fx-font-weight:bold;
                       "/>

                <TableView fx:id="usersTable"
                           prefHeight="250"
                           style="
                           -fx-background-color: transparent;
                           -fx-control-inner-background: rgba(10,20,50,0.95);
                           -fx-table-cell-border-color: rgba(0,229,255,0.20);
                           "/>

            </VBox>

            <VBox spacing="12"
                  VBox.vgrow="ALWAYS"
                  style="
                  -fx-background-color: rgba(5,15,45,0.80);
                  -fx-border-color:#ff00ff;
                  -fx-border-radius:20;
                  -fx-background-radius:20;
                  -fx-padding:18;
                  ">

                <Label text="⚡ LIVE AUCTIONS CONTROL"
                       style="
                       -fx-text-fill:#ff00ff;
                       -fx-font-size:18;
                       -fx-font-weight:bold;
                       "/>

                <TableView fx:id="auctionsTable"
                           prefHeight="280"
                           style="
                           -fx-background-color: transparent;
                           -fx-control-inner-background: rgba(10,20,50,0.95);
                           -fx-table-cell-border-color: rgba(255,0,255,0.20);
                           "/>

            </VBox>

        </VBox>
    </center>
    <bottom>

        <HBox alignment="CENTER_LEFT"
              spacing="10"
              style="
              -fx-background-color: rgba(5,5,35,0.92);
              -fx-border-color: #ff00ff;
              -fx-border-width: 1 0 0 0;
              -fx-padding: 10 20;
              ">

            <Label text="SYSTEM STATUS:"
                   style="
                   -fx-text-fill:#00e5ff;
                   -fx-font-weight:bold;
                   "/>

            <Label fx:id="statusLabel"
                   text="Ready"
                   style="
                   -fx-text-fill:white;
                   -fx-font-size:13;
                   "/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label text="BidPlaza Admin Panel"
                   style="
                   -fx-text-fill:#ff00ff;
                   -fx-font-size:12;
                   -fx-font-weight:bold;
                   "/>

        </HBox>

    </bottom>

</BorderPane>