<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.openjfx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:id="rootPane"
            fx:controller="com.bidplaza.ui.controller.ProfileController"
            styleClass="profile-background">

    <center>
        <VBox spacing="25" alignment="CENTER">
            <padding>
                <Insets top="30" right="30" bottom="30" left="30"/>
            </padding>

            <Label text="Thong tin ca nhan" styleClass="profile-title"/>

            <HBox spacing="30" alignment="CENTER">
                <VBox spacing="10" prefWidth="320" styleClass="neon-card">
                    <Label text="Username:" styleClass="field-label"/>
                    <Label fx:id="usernameLabel" text="-" styleClass="field-value"/>
                    
                    <Label text="Email:" styleClass="field-label"/>
                    <Label fx:id="emailLabel" text="-" styleClass="field-value"/>
                    
                    <Label text="Vai tro:" styleClass="field-label"/>
                    <Label fx:id="roleLabel" text="-" styleClass="role-value"/>
                </VBox>

                <VBox spacing="10" prefWidth="320" styleClass="neon-card">
                    <Label fx:id="statsTitle" text="Thong ke" styleClass="card-title"/>
                    <Label fx:id="stat1Label" text="-" styleClass="stat-label"/>
                    <Label fx:id="stat2Label" text="-" styleClass="stat-label"/>
                    <Label fx:id="stat3Label" text="-" styleClass="stat-label"/>
                </VBox>
            </HBox>

            <VBox spacing="15" maxWidth="670" styleClass="password-box">
                <Label text="Doi mat khau" styleClass="card-title"/>
                <HBox spacing="15">
                    <PasswordField fx:id="oldPasswordField" promptText="Mat khau cu" styleClass="cyber-input" HBox.hgrow="ALWAYS"/>
                    <PasswordField fx:id="newPasswordField" promptText="Mat khau moi" styleClass="cyber-input" HBox.hgrow="ALWAYS"/>
                </HBox>
                <Button text="Xac nhan" onAction="#handleChangePassword" styleClass="cyber-button"/>
                <Label fx:id="passwordResultLabel" styleClass="stat-label"/>
            </VBox>

            <Button text="Quay lai" onAction="#handleBack" styleClass="back-button"/>
        </VBox>
    </center>
</BorderPane>
