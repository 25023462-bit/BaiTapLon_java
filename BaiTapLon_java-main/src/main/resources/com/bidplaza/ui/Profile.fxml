<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.openjfx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:id="rootPane"
            fx:controller="com.bidplaza.ui.controller.ProfileController"
            style="-fx-background-color: #f4f7fb;">

    <center>
        <VBox spacing="20">
            <padding>
                <Insets top="30" right="30" bottom="30" left="30"/>
            </padding>

            <Label text="Thong tin ca nhan"
                   style="-fx-font-size: 26; -fx-font-weight: bold;"/>

            <HBox spacing="20">
                <VBox spacing="8" prefWidth="320"
                      style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 20;">
                    <Label text="Username:"/>
                    <Label fx:id="usernameLabel" text="-"
                           style="-fx-font-size: 18; -fx-font-weight: bold;"/>
                    <Label text="Email:"/>
                    <Label fx:id="emailLabel" text="-"
                           style="-fx-font-size: 16;"/>
                    <Label text="Vai tro:"/>
                    <Label fx:id="roleLabel" text="-"
                           style="-fx-font-size: 16; -fx-font-weight: bold;"/>
                </VBox>

                <VBox spacing="8" prefWidth="320"
                      style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 20;">
                    <Label fx:id="statsTitle" text="Thong ke"
                           style="-fx-font-size: 18; -fx-font-weight: bold;"/>
                    <Label fx:id="stat1Label" text="-"/>
                    <Label fx:id="stat2Label" text="-"/>
                    <Label fx:id="stat3Label" text="-"/>
                </VBox>
            </HBox>

            <TitledPane text="Doi mat khau" expanded="true">
                <VBox spacing="10">
                    <padding>
                        <Insets top="12" right="12" bottom="12" left="12"/>
                    </padding>
                    <PasswordField fx:id="oldPasswordField" promptText="Mat khau cu"/>
                    <PasswordField fx:id="newPasswordField" promptText="Mat khau moi"/>
                    <Button text="Xac nhan" onAction="#handleChangePassword"/>
                    <Label fx:id="passwordResultLabel"/>
                </VBox>
            </TitledPane>

            <Button text="Quay lai" onAction="#handleBack"/>
        </VBox>
    </center>
</BorderPane>
