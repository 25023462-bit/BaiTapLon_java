<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.bidplaza.ui.controller.LoginController">

    <children>

        <!-- Background -->
        <AnchorPane prefWidth="1200"
                    prefHeight="700"
                    style="-fx-background-image: url('/images/register-bg.png');
                           -fx-background-size: cover;
                           -fx-background-position: center;">

            <!-- Dark Overlay -->
            <Pane prefWidth="1200"
                  prefHeight="700"
                  style="-fx-background-color: rgba(0,0,0,0.45);" />

            <!-- Main Layout -->
            <HBox prefWidth="1200"
                  prefHeight="700"
                  alignment="CENTER_LEFT"
                  spacing="120"
                  AnchorPane.topAnchor="0"
                  AnchorPane.bottomAnchor="0"
                  AnchorPane.leftAnchor="0"
                  AnchorPane.rightAnchor="0">

                <padding>
                    <Insets top="0" right="80" bottom="0" left="80"/>
                </padding>

                <!-- Login Card -->
                <VBox spacing="16"
                      alignment="CENTER_LEFT"
                      maxWidth="420"
                      prefWidth="420"
                      style="-fx-background-color: rgba(10,15,30,0.72);
                             -fx-background-radius: 26;
                             -fx-border-color: rgba(0,255,255,0.35);
                             -fx-border-radius: 26;
                             -fx-padding: 38;
                             -fx-effect: dropshadow(gaussian, rgba(0,255,255,0.25), 35, 0.25, 0, 0);">

                    <!-- Logo -->
                    <VBox spacing="2">

                        <Label text="BidPlaza"
                               style="-fx-font-size: 34px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: linear-gradient(to right, #00f5ff, #ff4dff);" />

                        <Label text="Online Auction Platform"
                               style="-fx-font-size: 13px;
                                      -fx-text-fill: #dfe6e9;" />

                    </VBox>

                    <Region prefHeight="10"/>

                    <!-- Title -->
                    <Label text="Login Account"
                           style="-fx-font-size: 30px;
                                  -fx-font-weight: bold;
                                  -fx-text-fill: white;" />

                    <Label text="Access your BidPlaza dashboard"
                           style="-fx-font-size: 14px;
                                  -fx-text-fill: #dfe6e9;" />

                    <!-- Username -->
                    <VBox spacing="8">

                        <Label text="Username"
                               style="-fx-font-size: 15px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: white;" />

                        <TextField fx:id="usernameField"
                                   promptText="Enter username"
                                   prefWidth="320"
                                   prefHeight="46"
                                   style="-fx-background-color: rgba(0,0,0,0.35);
                                          -fx-border-color: #00eaff;
                                          -fx-border-radius: 12;
                                          -fx-background-radius: 12;
                                          -fx-text-fill: white;
                                          -fx-prompt-text-fill: #95a5a6;
                                          -fx-padding: 12;
                                          -fx-font-size: 14px;" />
                    </VBox>

                    <!-- Password -->
                    <VBox spacing="8">

                        <Label text="Password"
                               style="-fx-font-size: 15px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: white;" />

                        <PasswordField fx:id="passwordField"
                                       promptText="Enter password"
                                       prefWidth="320"
                                       prefHeight="46"
                                       style="-fx-background-color: rgba(0,0,0,0.35);
                                              -fx-border-color: #00eaff;
                                              -fx-border-radius: 12;
                                              -fx-background-radius: 12;
                                              -fx-text-fill: white;
                                              -fx-prompt-text-fill: #95a5a6;
                                              -fx-padding: 12;
                                              -fx-font-size: 14px;" />
                    </VBox>

                    <!-- Role -->
                    <VBox spacing="8">

                        <Label text="Role"
                               style="-fx-font-size: 15px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: white;" />

                        <ComboBox fx:id="roleCombo"
                                  prefWidth="320"
                                  prefHeight="46"
                                  style="-fx-background-color: rgba(0,0,0,0.35);
                                         -fx-border-color: #00eaff;
                                         -fx-border-radius: 12;
                                         -fx-background-radius: 12;
                                         -fx-font-size: 14px;" />
                    </VBox>

                    <!-- Error -->
                    <Label fx:id="errorLabel"
                           text=""
                           style="-fx-font-size: 13px;
                                  -fx-text-fill: #ff7675;" />

                    <!-- Login Button -->
                    <Button text="LOGIN"
                            prefWidth="320"
                            prefHeight="48"
                            onAction="#handleLogin"
                            style="-fx-background-color: linear-gradient(to right, #00f5ff, #00a8ff);
                                   -fx-text-fill: white;
                                   -fx-font-size: 16px;
                                   -fx-font-weight: bold;
                                   -fx-background-radius: 14;
                                   -fx-cursor: hand;" />

                    <!-- Register Button -->
                    <Button text="CREATE ACCOUNT"
                            prefWidth="320"
                            prefHeight="48"
                            onAction="#openRegister"
                            style="-fx-background-color: transparent;
                                   -fx-text-fill: #00f5ff;
                                   -fx-font-size: 15px;
                                   -fx-font-weight: bold;
                                   -fx-border-color: #00f5ff;
                                   -fx-border-width: 1.5;
                                   -fx-border-radius: 14;
                                   -fx-background-radius: 14;
                                   -fx-cursor: hand;" />

                </VBox>

            </HBox>

        </AnchorPane>

    </children>

</StackPane>